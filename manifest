chrome.runtime.onInstalled.addListener(() => {
  console.log('Sparx Science AI Extension installed');
  
  // Initialize default settings
  chrome.storage.sync.get(['apiKey', 'model', 'temperature'], (result) => {
    if (!result.apiKey) {
      chrome.storage.sync.set({
