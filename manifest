document.addEventListener('DOMContentLoaded', async () => {
  const [tab] = await chrome.tabs.query({active: true, currentWindow: true});
  
  chrome.tabs.sendMessage(tab.id, {action: 'getQuestion'}, (response) => {
    if (response && response.question) {
      currentQuestion = response.question;
      document.getElementById('question-text').textContent = currentQuestion;
    } else {
      document.getElementById('question-text').textContent = 'No question found on this page';
    }
  });
});

document.getElementById('get-answer-btn').addEventListener('click', async () => {
  if (!currentQuestion) {
    showError('No question to solve');
    return;
  }
  
  showLoading(true);
  
  const settings = await chrome.storage.sync.get(['apiKey', 'model', 'temperature']);
  
  if (!settings.apiKey) {
    showError('API key not configured. Please go to settings.');
    showLoading(false);
    return;
  }
  
  try {
    const response = await fetch('https://api.openai.com/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${settings.apiKey}`
      },
      body: JSON.stringify({
        model: settings.model || 'gpt-3.5-turbo',
        temperature: settings.temperature || 0.7,
        messages: [{
          role: 'user',
          content: `You are a science tutor. Answer this Sparx Science question concisely and clearly:\n\n${currentQuestion}\n\nProvide a direct answer with step-by-step working.`
        }],
        max_tokens: 500
      })
    });
    
    const data = await response.json();
    
    if (data.choices && data.choices[0] && data.choices[0].message) {
      const answer = data.choices[0].message.content;
      document.getElementById('answer-text').textContent = answer;
      document.getElementById('answer-section').style.display = 'block';
      document.getElementById('get-explanation-btn').style.display = 'inline-block';
      showLoading(false);
    } else {
      showError('Failed to generate answer');
    }
  } catch (error) {
    showError(`Error: ${error.message}`);
  }
  
  showLoading(false);
});

document.getElementById('get-explanation-btn').addEventListener('click', async () => {
  showLoading(true);
  
  const settings = await chrome.storage.sync.get(['apiKey', 'model']);
  
  try {
    const response = await fetch('https://api.openai.com/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${settings.apiKey}`
      },
      body: JSON.stringify({
        model: settings.model || 'gpt-3.5-turbo',
        temperature: 0.5,
        messages: [{
          role: 'user',
          content: `Provide a detailed educational explanation for this science question:\n\n${currentQuestion}\n\nInclude key concepts, formulas, and why the answer is correct.`
        }],
        max_tokens: 1000
      })
    });
    
    const data = await response.json();
    
    if (data.choices && data.choices[0]) {
      const explanation = data.choices[0].message.content;
      document.getElementById('explanation-text').textContent = explanation;
      document.getElementById('explanation-section').style.display = 'block';
    } else {
      showError('Failed to generate explanation');
